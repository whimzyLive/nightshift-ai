{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/site/**",
              "components/terminal/**",
              "ui_kits/docs/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|owns|glyph|tone|status|standby|style|key|ref|className|style|children)$/]",
        "message": "<AgentCard> doesn't accept that prop. Declared props: name, owns, glyph, tone, status, standby, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|info|cyan|green)$/]",
        "message": "<AgentCard> tone must be one of 'accent' | 'info' | 'cyan' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|solid|mono|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, solid, mono, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|info|success|warning|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|mono|disabled|loading|iconLeft|iconRight|fullWidth|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, mono, disabled, loading, iconLeft, iconRight, fullWidth, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|glow|interactive|padding|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, glow, interactive, padding, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|language|filename|showLineNumbers|copyable|style|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: code, language, filename, showLineNumbers, copyable, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:command|args|description|agents|output|style|key|ref|className|style|children)$/]",
        "message": "<CommandCard> doesn't accept that prop. Declared props: command, args, description, agents, output, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|items|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: title, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='InstallSnippet'] > JSXAttribute > JSXIdentifier[name!=/^(?:command|prompt|label|key|ref|className|style|children)$/]",
        "message": "<InstallSnippet> doesn't accept that prop. Declared props: command, prompt, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='PipelineStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:command|label|agent|status|key|ref|className|style|children)$/]",
        "message": "<PipelineStage> doesn't accept that prop. Declared props: command, label, agent, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='PipelineStage'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:idle|active|done)$/]",
        "message": "<PipelineStage> status must be one of 'idle' | 'active' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|mono|muted|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, header, align, mono, muted."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TermLineSpec'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|tone|prompt|agent|indent|dim|key|ref|className|style|children)$/]",
        "message": "<TermLineSpec> doesn't accept that prop. Declared props: text, tone, prompt, agent, indent, dim."
      },
      {
        "selector": "JSXOpeningElement[name.name='TermLineSpec'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|success|warning|danger|info|muted|accent)$/]",
        "message": "<TermLineSpec> tone must be one of 'default' | 'success' | 'warning' | 'danger' | 'info' | 'muted' | 'accent'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
