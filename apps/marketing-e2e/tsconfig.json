{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out-tsc/playwright",
    "sourceMap": false,
    // page.evaluate() callbacks run in the browser, not Node — they need DOM
    // types (getComputedStyle, document, etc.) that tsconfig.base.json
    // deliberately omits for the rest of the workspace.
    "lib": ["es2022", "dom"]
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "test-output",
    "eslint.config.js",
    "eslint.config.mjs",
    "eslint.config.cjs"
  ]
}
