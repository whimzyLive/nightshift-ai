{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "rootDir": ".",
    "types": ["jest", "node"],
    "tsBuildInfoFile": "./out-tsc/jest/tsconfig.spec.tsbuildinfo"
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.d.ts",
    "specs/**/*.ts",
    "specs/**/*.tsx",
    "specs/**/*.d.ts"
  ],
  "exclude": ["out-tsc", "dist", "node_modules", ".next"]
}
