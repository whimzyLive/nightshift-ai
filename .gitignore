# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.nx/migrate-runs
.claude/worktrees
.claude/settings.local.json

# Next.js
.next
out

test-output

.nx/polygraph

.DS_Store

# fork-local org token denylist for portability-lint (keep the public plugin org-neutral)
tools/portability-denylist.txt

# agent scratch — SDLC plugin temp files (auto-cleaned, never commit)
.tmp/

# gtm plugin-root marker — per-session cache, never commit (nightshift dogfoods gtm too)
.claude/.gtm-plugin-root

# Ignore env files for local development (never commit)
.env
.env*
!.env.example

# sdlc plugin-root marker — user/machine-specific cache path, never commit (rewritten by /sdlc:init)
.claude/.sdlc-plugin-root
