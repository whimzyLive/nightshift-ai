# Hoist sharp + its platform-specific native packages (@img/*) to the top-level
# node_modules so Next.js file tracing (nft) can resolve and bundle them into the
# serverless function. pnpm's default nested .pnpm store layout hides the dlopen'd
# @img/sharp-libvips-<platform> .so from nft, causing Payload's admin/image routes
# to 500 on Vercel with "libvips-cpp.so.*: cannot open shared object file".
public-hoist-pattern[]=*@img*
public-hoist-pattern[]=sharp
